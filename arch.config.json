{
  "version": "1.3.0",
  "archProfile": "full",
  "protocolVersion": "1.1.0",
  "minimumCliVersion": "1.1.0",
  "currentSprint": "sprint/v1.3.0-2026-06",
  "strategies": {
    "1-code-reasoning": {
      "M": [
        {
          "provider": "claude-code",
          "model": "sonnet"
        },
        {
          "provider": "gemini",
          "model": "sonnet"
        },
        {
          "provider": "ollama",
          "model": "qwen2.5-coder:7b"
        }
      ],
      "L": [
        {
          "provider": "claude-code",
          "model": "opus"
        },
        {
          "provider": "gemini",
          "model": "pro"
        }
      ]
    },
    "2-code-generation": {
      "M": [
        {
          "provider": "claude-code",
          "model": "sonnet"
        },
        {
          "provider": "gemini",
          "model": "sonnet"
        },
        {
          "provider": "ollama",
          "model": "qwen2.5-coder:7b"
        }
      ]
    },
    "default": {
      "XS": [
        {
          "provider": "ollama",
          "model": "qwen2.5-coder:1.5b"
        },
        {
          "provider": "gemini",
          "model": "flash"
        }
      ],
      "S": [
        {
          "provider": "ollama",
          "model": "phi3:latest"
        },
        {
          "provider": "claude-code",
          "model": "haiku"
        }
      ],
      "M": [
        {
          "provider": "claude-code",
          "model": "sonnet"
        },
        {
          "provider": "gemini",
          "model": "sonnet"
        },
        {
          "provider": "ollama",
          "model": "qwen2.5-coder:7b"
        }
      ],
      "L": [
        {
          "provider": "claude-code",
          "model": "opus"
        },
        {
          "provider": "gemini",
          "model": "pro"
        }
      ]
    }
  },
  "governance": {
    "conductEveryN": 5,
    "batchWritingTasks": false,
    "execTimeoutMinutes": 10,
    "sprawlThresholds": {
      ".arch": 30,
      "docs": 38,
      ".": 25
    },
    "negativeConstraints": [
      "No new npm dependencies for tasks smaller than M",
      "No modifying protectedPaths without a preceding ADR",
      "No major architectural changes without an approved ADR"
    ],
    "protectedPaths": [
      "docs/adr/",
      "cli/src/main/ts/domain/models/",
      "cli/src/main/ts/domain/repositories/"
    ],
    "hanseiSinceTaskId": 195,
    "corpusAuditEveryN": 10,
    "corpusAuditThresholdWarn": 80,
    "corpusAuditThresholdHalt": 60,
    "deadCodeExemptions": [
      "verifiability-scorer",
      "causal-graph"
    ]
  },
  "reflect": {
    "deepCadenceN": 50,
    "thresholds": {
      "minEngagementRate": 0.5,
      "maxUnobservedWithProposalRate": 0.3,
      "persistenceN": 3
    }
  },
  "muri": {
    "XS": {
      "turns": 5,
      "cost": 0.05
    },
    "S": {
      "turns": 15,
      "cost": 0.15
    },
    "M": {
      "turns": 40,
      "cost": 0.5
    },
    "L": {
      "turns": 100,
      "cost": 2
    },
    "XL": {
      "turns": 200,
      "cost": 5
    }
  },
  "refinement": {
    "ttlCycles": 10
  },
  "contextBudget": {
    "docs/tasks": 1500,
    "docs/archive": 8000,
    "docs/refinement": 3000,
    "docs/adr": 2000
  },
  "paths": {
    "tasks": "docs/tasks",
    "archive": "docs/archive",
    "guidelines": "docs/guidelines",
    "agents": "docs/agents",
    "refinement": "docs/refinement",
    "refinementArchive": "docs/refinement/archive",
    "adr": "docs/adr",
    "inbox": "docs/INBOX.md",
    "events": "docs/EVENTS.md",
    "statusProjection": ".arch/status-projection.json"
  },
  "contextRules": {
    "testing-a-change.md": {
      "taskClasses": [
        "2-code-generation",
        "7-operations"
      ]
    },
    "versioning.md": {
      "taskClasses": [
        "2-code-generation"
      ]
    },
    "core.md": {
      "taskClasses": [
        "2-code-generation",
        "6-writing",
        "7-operations"
      ]
    },
    "models.md": {
      "taskClasses": [
        "2-code-generation"
      ]
    },
    "autonomy.md": {
      "taskClasses": [
        "7-operations"
      ]
    },
    "bugs.md": {
      "taskClasses": [
        "2-code-generation",
        "7-operations"
      ]
    },
    "resources.md": {
      "taskClasses": [
        "2-code-generation",
        "7-operations"
      ]
    },
    "documentation.md": {
      "taskClasses": [
        "6-writing"
      ]
    }
  },
  "clis": [
    {
      "name": "opencode",
      "bin": "opencode",
      "template": "opencode run --title \"arch-analyze\" \"{prompt}\""
    },
    {
      "name": "claude",
      "bin": "claude",
      "template": "claude -p \"{prompt}\" --dangerously-skip-permissions"
    },
    {
      "name": "ollama",
      "bin": "curl",
      "template": "jq -Rs '{model: \"{model}\", prompt: ., stream: true, options: {num_ctx: 8192, num_predict: 4096, temperature: 0.1}}' {prompt_file} | curl -N -s -X POST http://127.0.0.1:11434/api/generate -d @- | jq -j --unbuffered .response"
    }
  ],
  "providers": [
    {
      "name": "opencode",
      "type": "bridge",
      "bin": "opencode",
      "template": "opencode run --title \"arch-analyze\" \"{prompt}\""
    },
    {
      "name": "claude-code",
      "type": "bridge",
      "bin": "claude",
      "template": "claude -p \"{prompt}\" --dangerously-skip-permissions"
    },
    {
      "name": "codex",
      "type": "bridge",
      "bin": "codex",
      "template": "codex \"{prompt}\""
    },
    {
      "name": "claude",
      "type": "bridge",
      "bin": "claude",
      "template": "claude -p \"{prompt}\" --dangerously-skip-permissions"
    },
    {
      "name": "ollama",
      "type": "native",
      "endpoint": "http://127.0.0.1:11434/v1",
      "apiKey": "ollama",
      "coreMode": true,
      "_coreModeNote": "Load AGENTS.md Execution Session section for sessions using this provider"
    },
    {
      "name": "openrouter",
      "type": "native",
      "endpoint": "https://openrouter.ai/api/v1",
      "apiKeyEnv": "OPENROUTER_API_KEY"
    },
    {
      "name": "gemini",
      "type": "bridge",
      "bin": "gemini",
      "template": "gemini -p \"{prompt}\" -y",
      "_deprecated": "Use opencode instead \u2014 Gemini deprecated in AGY context"
    }
  ],
  "costs": {
    "_schema": "Written by arch exec bridge after each session to .arch/costs/TASK-XXX.json",
    "_fields": {
      "taskId": "string \u2014 the task ID (e.g. TASK-XXX)",
      "actor": "string \u2014 provider/model (e.g. claude-code/sonnet)",
      "inputTokens": "number \u2014 tokens consumed from context",
      "outputTokens": "number \u2014 tokens generated",
      "estimatedCostUSD": "number \u2014 estimated cost in USD (0.0 for local models)",
      "sessionId": "string | null \u2014 optional session identifier"
    },
    "_example": {
      "taskId": "TASK-246",
      "actor": "claude-code/sonnet",
      "inputTokens": 12400,
      "outputTokens": 3200,
      "estimatedCostUSD": 0.048,
      "sessionId": null
    }
  },
  "sprintCloseAfterN": 15,
  "sprintAutoNamePrefix": "sprint/v",
  "archVersion": "1.3.0",
  "corpus": {
    "remotes": [
      {
        "url": "https://github.com/valentinlineiro/smartcart-os",
        "slug": "smartcart",
        "syncOnGovern": true
      }
    ]
  },
  "policies": {
    "forbiddenDependencies": [
      {
        "from": "cli/src/main/ts/infrastructure",
        "to": "../domain",
        "message": "Infrastructure must not import domain internals directly"
      }
    ],
    "requiredTestCoverage": 30,
    "namingInvariants": []
  },
  "modelTiers": {
    "local": {
      "analyze": "opencode",
      "capture": "claude-code",
      "reflect": "claude-code"
    },
    "cloud": {
      "analyze": "claude-code",
      "capture": "claude-code",
      "reflect": "claude-code"
    }
  },
  "mission": {
    "autonomousScope": [
      "bug-fix",
      "simplification",
      "protocol-fix",
      "dependency-update",
      "documentation",
      "test-coverage",
      "new-collector",
      "scoring-tuning",
      "dashboard-copy"
    ],
    "humanGated": [
      "new-command",
      "new-subsystem",
      "protocol-change",
      "external-integration",
      "schema-change",
      "new-api-endpoint",
      "new-dependency",
      "scoring-architecture",
      "output-format-change",
      "cron-change",
      "security-change"
    ]
  }
}